# Backup files
.cursorrules.backup
*.backup

# OS files
.DS_Store
Thumbs.db

# Editor files (if not shared)
.vscode/
.idea/
*.swp
*.swo
*~

# Cursor IDE files (but track .cursor/commands/)
.cursor/*
!.cursor/commands/
!.cursor/commands/**

# Gemini CLI files (but track .gemini/ config files)
.gemini/active_mission.log

# Worktrees
.worktrees/

# Node.js
node_modules/

# Website build artifacts
website/dist/
website/.astro/
website/node_modules/

# Synced content (generated at build time by scripts/sync-content.sh)
website/src/content/docs/getting-started/
website/src/content/docs/guides/
website/src/content/docs/reference/
website/src/content/docs/standards/
website/src/content/docs/changelog.md

# Temporary files
*.tmp
*.temp
*.log

# Standards temporary files directory (used by Cursor AI commands and scripts)
.standards_tmp/

# PR content generation temporary files (legacy - now in .standards_tmp/)
pr-content-*.txt
/tmp/pr-content-*.txt

# Standards sync temporary files (for client projects using this as submodule)
standards-sync-*.tmp

# Git submodule tracking (when this repo is used as submodule in other projects)
.gitmodules.local

