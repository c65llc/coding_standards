{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make ci)",
      "Bash(make check)",
      "Bash(make lint)",
      "Bash(make test)",
      "Bash(make fmt)",
      "Bash(make ls)",
      "Bash(make seed)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git worktree*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
